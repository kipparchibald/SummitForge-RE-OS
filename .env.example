# SummitForge RE OS Environment
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token
OPENAI_API_KEY=sk-your-openai-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# DEMO / Preview mode — set to true to bypass limits and show banner (great for client previews)
# For production deploys: set NEXT_PUBLIC_DEMO_MODE=false (or omit) → branding lock + no demo UI
# AUTH: demo mode also bypasses login. In production (DEMO_MODE=false) every page
# requires a Supabase session; with no Supabase configured the app fail-closes (503).
# Create users in Supabase Dashboard > Authentication > Users, or enable magic links.
NEXT_PUBLIC_DEMO_MODE=true

# Monetization (Stripe) — add real keys later
# STRIPE_SECRET_KEY=sk_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# For white-label / multi-tenant
# SUPABASE_SERVICE_ROLE_KEY=your-service-role

# === NAVICA / IDX Real-time Feed (Archibald-Bagley / Snake River MLS) ===
# Get credentials from your MLS (Snake River Regional MLS) or Navica provider for IDX/RETS/RESO Web API access.
# Typical: a JSON or OData endpoint + auth (Bearer token or basic).
# Example (replace with your real private feed):
# NAVICA_IDX_URL=https://your-idx-provider.com/reso/odata/Property?$filter=City eq 'Rigby' or similar
# NAVICA_API_KEY=your_bearer_or_key_here
# Or for RETS-style: NAVICA_RETS_URL + username/pass (advanced - use library if needed)
NAVICA_IDX_URL=
NAVICA_API_KEY=

# Fallback demo data is always available when these are empty or in DEMO_MODE.

# === Vercel Cron Jobs (background Navica sync) ===
# Generate a secure random string (>=16 chars). When set, Vercel Cron automatically
# sends "Authorization: Bearer <CRON_SECRET>" on scheduled invocations.
# Leave blank for local dev / DEMO (endpoint allows unauthenticated calls and uses demo data).
# CRON_SECRET=your-long-random-secret-here
CRON_SECRET=

# === Land Deal Digest (optional email) ===
# Nightly /api/cron/land-digest scores raw-land listings and (optionally) emails deals that pencil.
# Without these, it still runs and persists to Supabase 'land_deals'; with them, it also emails.
# RESEND_API_KEY=re_your_key
# DIGEST_FROM=deals@yourdomain.com      # a verified Resend sender/domain
# DIGEST_TO=you@yourdomain.com          # comma-separate for multiple recipients

# Vercel deployment — set all above + MAPBOX + OPENAI in project settings
# Add CRON_SECRET in Vercel dashboard (Settings > Environment Variables) to enable secured hourly sync.
#
# PRODUCTION EXAMPLE (add these in Vercel, set DEMO_MODE=false):
# NEXT_PUBLIC_DEMO_MODE=false
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.real...
# OPENAI_API_KEY=sk-real...
# NAVICA_IDX_URL=https://...
# etc.


# === Twilio SMS (optional — falls back to simulated SMS) ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+12085551234
