# SummitForge Environment Variables
# Copy to .env.local and fill in real values

# Supabase (optional — app works with localStorage without these)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Twilio SMS (optional — falls back to simulated SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+12085551234

# Mapbox (for GIS / monitoring maps)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# xAI (for AI agents / valuation / marketing)
XAI_API_KEY=xai-your-key
